{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "cbx-audit",
          "rules": [
            {
              "id": "S3-002",
              "name": "S3 bucket encryption not configured",
              "help": {
                "text": "The S3 bucket lacks server-side encryption configuration.\n\nRemediation: Enable SSE-S3 or SSE-KMS encryption on the bucket."
              },
              "properties": {
                "severity": "high"
              }
            },
            {
              "id": "S3-001",
              "name": "S3 bucket versioning not enabled",
              "help": {
                "text": "The S3 bucket does not have versioning enabled, which prevents recovery from accidental deletion or overwrites.\n\nRemediation: Enable versioning on the S3 bucket."
              },
              "properties": {
                "severity": "warning"
              }
            },
            {
              "id": "EC2-001",
              "name": "Security group allows unrestricted ingress",
              "help": {
                "text": "A security group rule allows ingress from 0.0.0.0/0 on a sensitive port.\n\nRemediation: Restrict security group ingress to specific CIDR blocks."
              },
              "properties": {
                "severity": "high"
              }
            },
            {
              "id": "LAMBDA-001",
              "name": "Lambda function environment variables may contain secrets",
              "help": {
                "text": "Environment variables on Lambda functions are visible in plain text.\n\nRemediation: Use AWS Secrets Manager or Parameter Store for sensitive values."
              },
              "properties": {
                "severity": "info"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "S3-002",
          "message": {
            "text": "The S3 bucket lacks server-side encryption configuration."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "bucket-1"
                }
              }
            }
          ]
        },
        {
          "ruleId": "S3-001",
          "message": {
            "text": "The S3 bucket does not have versioning enabled, which prevents recovery from accidental deletion or overwrites."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "bucket-1"
                }
              }
            }
          ]
        },
        {
          "ruleId": "EC2-001",
          "message": {
            "text": "A security group rule allows ingress from 0.0.0.0/0 on a sensitive port."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "sg-1"
                }
              }
            }
          ]
        },
        {
          "ruleId": "LAMBDA-001",
          "message": {
            "text": "Environment variables on Lambda functions are visible in plain text."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "func-1"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}